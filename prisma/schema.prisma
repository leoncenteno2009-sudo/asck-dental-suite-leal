generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id            String   @id
  nombre        String
  email         String   @unique
  claveHash     String
  rol           String
  fechaCreacion DateTime @default(now())
}

model Paciente {
  id                 String             @id
  nombre             String
  avatar             String?
  iniciales          String
  fechaNacimiento    String
  edad               Int
  telefono           String
  alergias           String?
  nivelRiesgo        String
  estado             String             @default("Activo")
  origen             String?
  fechaCreacion      DateTime           @default(now())
  fechaActualizacion DateTime           @updatedAt
  citas              Cita[]
  presupuestos       Presupuesto[]
  odontograma        Odontograma?
  historialMedico    HistorialMedico?
  adjuntos           AdjuntoClinico[]

  @@index([nombre])
}

model Cita {
  id                 String   @id
  fecha              String   @default("2026-06-16")
  hora               String
  pacienteId         String
  tratamiento        String
  estado             String
  doctor             String
  horaInicio         Float
  duracionHoras      Float
  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt
  paciente           Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  @@index([pacienteId])
  @@index([doctor, horaInicio])
  @@index([estado])
}

model Chat {
  id                 String   @id
  nombrePaciente     String
  iniciales          String
  avatar             String?
  ultimoMensaje      String
  hora               String
  esNuevo            Boolean  @default(false)
  mensajes           String
  fechaActualizacion DateTime @updatedAt
}

model Presupuesto {
  id                  String            @id
  pacienteId          String
  estado              String
  porcentajeDescuento Float             @default(0)
  fechaCreacion       DateTime          @default(now())
  fechaActualizacion  DateTime          @updatedAt
  paciente            Paciente          @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  items               ItemPresupuesto[]

  @@index([pacienteId])
  @@index([estado])
}

model ItemPresupuesto {
  id             String      @id
  presupuestoId  String
  codigo         String
  descripcion    String
  diente         String
  precioUnitario Float
  total          Float
  presupuesto    Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)

  @@index([presupuestoId])
}

model Odontograma {
  pacienteId         String   @id
  dientes            String
  intervenciones     String
  fechaActualizacion DateTime @updatedAt
  paciente           Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
}

model Notificacion {
  id            String   @id
  titulo        String
  descripcion   String
  tiempo        String
  leido         Boolean  @default(false)
  fechaCreacion DateTime @default(now())

  @@index([leido])
  @@index([fechaCreacion])
}

model RegistroAuditoria {
  id            String   @id
  actorId       String
  actorEmail    String
  accion        String
  tipoEntidad   String
  entidadId     String?
  ip            String?
  fechaCreacion DateTime @default(now())

  @@index([actorId])
  @@index([tipoEntidad])
  @@index([fechaCreacion])
}

model ConfiguracionClinica {
  id             String   @id @default("singleton")
  nombreClinica  String
  eslogan        String
  sistemaNotacion String
  numeroWhatsApp String
  modoCumplimiento String
  fechaActualizacion DateTime @updatedAt
}

model HistorialMedico {
  pacienteId         String   @id
  paciente           Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  alergias           String?
  medicamentos       String?
  enfermedades       String?
  cirugias           String?
  observaciones      String?

  seccionesOficiales String   @default("{}")
  seccionesFlexibles String   @default("{}")

  fechaCreacion      DateTime @default(now())
  fechaActualizacion DateTime @updatedAt
}

model AdjuntoClinico {
  id            String   @id @default(cuid())
  pacienteId    String
  paciente      Paciente @relation(fields: [pacienteId], references: [id], onDelete: Cascade)

  nombreArchivo  String
  nombreOriginal String
  tipoMime       String
  tamanoBytes    Int
  rutaArchivo    String

  categoria     String   @default("General")
  descripcion   String?
  subidoPor     String?
  fechaCreacion DateTime @default(now())
}
